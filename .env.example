# ──────────────────────────────────────────────
# PostgreSQL (open-webui와 동일한 DB를 바라봄)
# ──────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=open_webui
DB_USERNAME=postgres
DB_PASSWORD=

# ──────────────────────────────────────────────
# Open-WebUI
# ──────────────────────────────────────────────
# Open-WebUI 백엔드 URL
OPENWEBUI_URL=http://localhost:8080

# open-webui의 WEBUI_SECRET_KEY — 양쪽이 반드시 동일해야 함
WEBUI_SECRET_KEY=

# ──────────────────────────────────────────────
# API Gateway
# ──────────────────────────────────────────────
# Gateway JWT 서명 키 (반드시 변경할 것)
GATEWAY_JWT_SECRET=

# JWT 만료 폴백 (DB에 설정이 없을 때만 사용)
GATEWAY_JWT_EXPIRES_IN_FALLBACK=4w
